{
  "ci": {
    "collect": {
      "staticDistDir": "./docs",
      "url": [
        "http://localhost/index.html",
        "http://localhost/recipes/pasta-carbonara/index.html",
        "http://localhost/recipes/negroni/index.html",
        "http://localhost/food/index.html",
        "http://localhost/cocktails/index.html",
        "http://localhost/favorites/index.html",
        "http://localhost/shopping-list/index.html"
      ],
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["uses-http2", "redirects-http", "is-on-https"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "color-contrast": "error",
        "heading-order": "error",
        "html-has-lang": "error",
        "image-alt": "error",
        "label": "error",
        "link-name": "error",
        "meta-viewport": "error"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
